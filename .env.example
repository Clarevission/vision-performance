# ── Resend email (https://resend.com) ──────────────────────────────────────
# 1. Sign up at resend.com
# 2. Add & verify visionperformance.ca under Domains
# 3. Create an API key and paste it here
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address — must match your verified Resend domain
MAIL_FROM=Vision Performance <info@visionperformance.ca>

# Where contact form submissions are delivered
NOTIFY_EMAIL=info@visionperformance.ca

# ── App origin (set to your live domain in production) ─────────────────────
APP_ORIGIN=https://visionperformance.ca

# ── Server port ────────────────────────────────────────────────────────────
PORT=3000
